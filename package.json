{
  "name": "nexora",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "serve": "nx run demo:serve",
    "prepare": "husky",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint:all": "nx run-many -t lint",
    "lint:fix": "nx run-many -t lint --fix",
    "stylelint": "stylelint \"**/*.{css,scss}\" --allow-empty-input",
    "stylelint:fix": "stylelint \"**/*.{css,scss}\" --fix --allow-empty-input",
    "verify:tree-shake": "nx run demo:build --configuration=production && echo 'Production build done. To verify tooltip-only apps do not pull dialog/drawer: use an app that imports only @nexora-ui/tooltip, build, and grep the bundle for DialogService/DrawerService (see docs/DEVELOPMENT.md).'",
    "playwright:install": "playwright install --with-deps",
    "release:build:headless": "nx run-many -t build --projects=core,overlay,interactions,listbox-cdk,listbox,dropdown,popover,menu,tooltip,snackbar,select,combobox,mention,headless",
    "release:publish:headless": "for p in core overlay interactions listbox-cdk listbox dropdown popover menu tooltip snackbar select combobox mention headless; do npm publish \"dist/libs/headless/$p\" --access public; done",
    "release:nx": "nx release --yes",
    "release:nx:dry-run": "nx release --dry-run --yes",
    "release:headless": "npm run release:build:headless && npm run release:publish:headless"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "prettier --write"
    ],
    "*.{html,md,json,yaml,yml}": [
      "prettier --write"
    ],
    "*.{css,scss}": [
      "stylelint --fix",
      "prettier --write"
    ]
  },
  "private": true,
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "~2.1.2",
    "@analogjs/vitest-angular": "~2.1.2",
    "@angular-devkit/core": "~21.1.0",
    "@angular-devkit/schematics": "~21.1.0",
    "@angular-eslint/eslint-plugin-template": "^21.2.0",
    "@angular-eslint/template-parser": "^21.2.0",
    "@angular/build": "~21.1.0",
    "@angular/cli": "~21.1.0",
    "@angular/compiler-cli": "~21.1.0",
    "@angular/language-service": "~21.1.0",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@eslint/js": "^9.8.0",
    "@nx/angular": "^22.5.1",
    "@nx/devkit": "22.5.1",
    "@nx/eslint": "22.5.1",
    "@nx/eslint-plugin": "22.5.1",
    "@nx/js": "22.5.4",
    "@nx/playwright": "22.5.1",
    "@nx/vite": "22.5.1",
    "@nx/vitest": "22.5.1",
    "@nx/web": "22.5.1",
    "@playwright/test": "^1.36.0",
    "@schematics/angular": "~21.1.0",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@types/node": "20.19.9",
    "@typescript-eslint/utils": "^8.40.0",
    "@vitest/coverage-v8": "^4.0.0",
    "@vitest/ui": "^4.0.8",
    "angular-eslint": "^21.0.1",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-playwright": "^1.6.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jsdom": "^27.1.0",
    "jsonc-eslint-parser": "^2.1.0",
    "lint-staged": "^16.2.7",
    "ng-packagr": "~21.1.0",
    "nx": "22.5.1",
    "postcss": "^8.4.5",
    "postcss-scss": "^4.0.9",
    "postcss-url": "~10.1.3",
    "prettier": "~3.6.2",
    "stylelint": "^17.3.0",
    "stylelint-config-prettier-scss": "^1.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "verdaccio": "^6.0.5",
    "vite": "^7.0.0",
    "vitest": "^4.0.8"
  },
  "dependencies": {
    "@angular/cdk": "~21.1.0",
    "@angular/common": "~21.1.0",
    "@angular/compiler": "~21.1.0",
    "@angular/core": "~21.1.0",
    "@angular/forms": "~21.1.0",
    "@angular/platform-browser": "~21.1.0",
    "@angular/router": "~21.1.0",
    "rxjs": "~7.8.0"
  },
  "nx": {
    "includedScripts": []
  },
  "engines": {
    "node": ">=20 <21"
  }
}
